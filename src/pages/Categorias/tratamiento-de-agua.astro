const fotosCatalogo = [
  {
    src: "/ath-logo.webp",
    alt: "ATH catálogo de tratamiento de agua",
    href: "../Marcas/ath" // Sustituye por el enlace al catálogo
  },
  {
    src: "/ceasa-logo.webp",
    alt: "Ceasa catálogo de tratamiento de agua",
    href: "../Marcas/ceasa" // Sustituye por el enlace al catálogo
  },
  {
    src: "/cepex.webp",
    alt: "Cepex catálogo de tratamiento de agua",
    href: "../Marcas/cepex" // Sustituye por el enlace al catálogo
  },
  {
    src: "/cillit.webp",
    alt: "Cillit catálogo de tratamiento de agua",
    href: "../Marcas/cillit" // Sustituye por el enlace al catálogo
  },
  {
    src: "/dropson.webp",
    alt: "Dropson catálogo de tratamiento de agua",
    href: "../Marcas/dropson" // Sustituye por el enlace al catálogo
  },
  {
    src: "/hidrowater.webp",
    alt: "Hidrowater catálogo de tratamiento de agua",
    href: "../Marcas/hidrowater" // Sustituye por el enlace al catálogo
  },
  {
    src: "/idegis.webp",
    alt: "Idegis catálogo de tratamiento de agua",
    href: "../Marcas/idegis" // Sustituye por el enlace al catálogo
  },
  {
    src: "/kinetico.webp",
    alt: "Kinetico catálogo de tratamiento de agua",
    href: "../Marcas/kinetico" // Sustituye por el enlace al catálogo
  },
   {
    src: '/osmofilter.webp',
    alt: 'Osmofilter catálogo de tratamiento de agua',  
    href: '../Marcas/osmofilter' // Sustituye por el enlace al catálogo
    },
     {
    src: '/premiertech-300x300.webp',
    alt: 'Premiertech catálogo de tratamiento de agua',  
    href: '../Marcas/premiertech' // Sustituye por el enlace al catálogo
    },
    {
    src: '/waterfilter.webp',
    alt: 'Waterfilter catálogo de tratamiento de agua',  
    href: '../Marcas/waterfilter' // Sustituye por el enlace al catálogo
    }
];

---

<Layout
  title="Tratamiento de Agua"
  description="Lorem ipsum dolor sit amet"
  category="Productos"
>
  <p>
    En Tiendas Achedosol te ofrecemos los mejores productos en tratamiento de
    agua.
  </p>
  <p>
    Somos especialistas en la venta, asesoramiento y distribución de productos
    de tratamiento de agua, trabajamos con todas las marcas y fabricantes
    lideres del mercado.
  </p>
  <p>
    Encuentra el producto en tratamiento de agua que buscas en Ariston, Aparici,
    Junkers y muchas más.
  </p>
  <Image src="/agua.jpg" alt="Tratamiento de agua en Achedosol" title="Tratamiento de agua en Achedosol" width={800} height={400} />
  <p>
    Solicita presupuesto sin compromiso o visita nuestras tiendas físicas en
    Estepona, San Pedro de Alcántara, Sotogrande, Sabinillas y Coín, te
    asesoramos para que elijas el producto que mejor se adapta a tus
    necesidades.
  </p>
  <p>
    En esta página podrás encontrar toda la información de las mejores marcas
    del sector. Comprar tratamiento de agua es muy fácil con nosotros. También
    estamos especializados en la gestión y venta de repuestos para tratamiento
    de agua.
  </p>
  <p>
    Consulta nuestros catálogos, tarifas de precios, fichas técnicas y más... de
    todas las marcas con las que trabajamos.
  </p>
 <h3 class="text-center">Marcas Destacadas</h3>
  
  <div class="fila-logos">
    <Image src="/hidrowater.webp" alt="Hidrowater" height={300} width={200}/>  
    <Image src="/dropson.webp" alt="Dropson" height={300} width={200}/>  
  </div>

  <h3 class="text-center">Todas nuestras marcas</h3>
  
  <Catalogo fotos={fotosCatalogo} />

</Layout>

<style>
  /* Estilos generales */
  .text-center {
    text-align: center;
  }

  /* Centrar la imagen grande */
  .container-hero {
    display: flex;
    justify-content: center;
    margin: 2rem 0;
  }

  .img-hero {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* --- LO MÁS IMPORTANTE PARA TU PREGUNTA --- */
  
  .fila-logos {
    display: flex;            /* Activa Flexbox */
    justify-content: center;  /* Centra horizontalmente las imágenes */
    align-items: center;      /* Alinea verticalmente si tienen distinta altura */
    
    /* 1. Evita que bajen a otra fila si no caben */
    flex-wrap: nowrap;        
    
    /* 2. Ajusta el espacio entre ellas (se encogerá en móvil) */
    gap: 2.5rem;              
    
    /* Pequeño ajuste para que no toquen los bordes de la pantalla */
    padding: 0 1rem;
    margin: 3rem 0;
    width: 100%;
    box-sizing: border-box;
  }

  /* Estilos para las etiquetas <img> dentro del contenedor (generadas por Astro) */
  .fila-logos img {
    /* 3. Definimos un ancho base ideal (ej. 200px) */
    width: 200px;
    
    /* 4. Pero restringimos su tamaño máximo al contenedor,
          permitiendo que Flexbox las encoja dinámicamente */
    max-width: 100%;
    height: auto;
    object-fit: contain; /* Asegura que el logo se vea entero sin recortarse */
    
    /* Opcional: para que se encojan de forma agresiva en pantallas muy pequeñas */
    flex-shrink: 1; 
  }

  /* Ajuste responsivo sutil para el espacio en pantallas muy pequeñas */
  @media (max-width: 480px) {
    .fila-logos {
      gap: 1rem; /* Reducimos la separación en móviles muy estrechos */
    }
    .fila-logos img {
        width: 150px; /* Reducimos el ancho base para pantallas diminutas */
    }
  }
  /* 3. CONFIGURACIÓN PARA ESCRITORIO (Pantallas mayores a 1024px) */
  @media (min-width: 1024px) {
    .fila-logos {
      /* ESPACIO EN ESCRITORIO: Aquí puedes subirlo todo lo que quieras */
      gap: 10rem; 
    }

    .fila-logos img {
      height: 120px; /* Un poco más grandes en PC para que luzcan */
    }
  }
</style>
