---

<Layout 
  title="Menú de Categorías" 
  description="Categorías de Achedosol" 
  category="Menu" 
  hideUI={true}
>

  <header class="top-header">
    <a href="/" class="logo" aria-label="Achedosol">
      <img src="/logo.webp" alt="Achedosol" />
    </a>
  </header>

  <div class="menu-container">
    <nav class="cat-nav">
      {categorias.map((grupo) => (
        <div class="cat-group">
          <button class="cat-trigger">
            <div class="cat-title-container">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox={grupo.viewBox} class="cat-icon">
                <path fill="currentColor" d={grupo.path} />
              </svg>
              <span class="cat-text">{grupo.titulo}</span>
            </div>
            <svg class="chevron-static" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          
          <div class="cat-content">
            <ul>
              {grupo.items.map((item) => (
                <li>
                  <a href={`/Categorias/${item.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-')}`}>
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </nav>
  </div>

  <script is:inline>
    function setupAccordion() {
      const groups = document.querySelectorAll('.cat-group');
      
      groups.forEach(group => {
        const trigger = group.querySelector('.cat-trigger');
        
        // Limpieza de eventos para Astro View Transitions
        const newTrigger = trigger.cloneNode(true);
        trigger.replaceWith(newTrigger);

        newTrigger.addEventListener('click', (e) => {
          e.preventDefault();
          const isActive = group.classList.contains('activo');

          // Cierra los demás acordeones
          groups.forEach(g => g.classList.remove('activo'));

          // Si estaba cerrado, lo abre
          if (!isActive) {
            group.classList.add('activo');
          }
        });
      });
    }

    setupAccordion();
    document.addEventListener('astro:after-swap', setupAccordion);
  </script>

</Layout>

<style>
  :root {
    --brand-blue: rgb(53, 117, 255);
    --text-white: #ffffff;
    --border-color: rgba(255, 255, 255, 0.2);
  }

  body {
    margin: 0;
    margin-left:-2rem;
    padding: 0;
    font-family: system-ui, -apple-system, sans-serif;
  }
  main{
    padding:0;
    margin:0;
  }

  /* --- Logo centrado --- */
  .top-header {
    background-color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .logo img {
    width: 10rem;
    height: auto;
    display: block;
  }

  /* --- Menú Principal --- */
  .menu-container {
    width: 100%;
    background-color: var(--brand-blue);
  }

  .cat-nav {
    display: flex;
    flex-direction: column;
    max-width: 100%;
    margin: 0 auto;
  }

  .cat-group {
    border-bottom: 1px solid var(--border-color);
  }

  .cat-group:last-child {
    border-bottom: none;
  }

  .cat-trigger {
    width: 100%;
    padding: 1.8rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: none;
    color: var(--text-white);
    cursor: pointer;
    text-align: left;
  }

  /* --- Ajuste de Icono y Título --- */
  .cat-title-container {
    display: flex;
    align-items: center;
    gap: 0.6rem; 
  }

  .cat-icon {
    flex-shrink: 0;
    transform: none !important;
  }

  .cat-text {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
  }

  .chevron-static {
    opacity: 0.7;
    transition: transform 0.5 ease;
  }

  .cat-group.activo .chevron-static {
  transform: rotate(180deg);
}

  /* --- Contenido desplegable --- */
  .cat-content {
    max-height: 0;
    overflow: hidden;
    background-color: rgba(0, 0, 0, 0.1);
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cat-group.activo .cat-content {
    max-height: 600px; 
  }

  .cat-content ul {
    list-style: none;
    margin: 0;
    padding: 1.5rem 2rem 1.5rem 4.5rem; 
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .cat-content a {
    color: var(--text-white);
    text-decoration: none;
    font-size: 1.15rem;
    opacity: 0.9;
    display: block;
    transition: opacity 0.2s;
  }

  .cat-content a:hover {
    opacity: 3;
    font-size: 1.2rem;
  }

  /* --- Modo Oscuro --- */
  :global(.dark) .top-header { background-color: #121212; }
  :global(.dark) .menu-container { background-color: #1a1a1a; }
  :global(.dark) .cat-group { border-bottom-color: #333; }
  :global(.dark) .cat-content { background-color: #222; }
</style>