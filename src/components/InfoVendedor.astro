---
// src/components/InfoVendedor.astro
interface Props {
  colorFondo: string;
  textoBiografico: string;
  imagenes?: string[];
}

const { colorFondo, textoBiografico, imagenes = [] } = Astro.props;
---

<section class="seccion-info" style={`background-color: ${colorFondo};`}>
  <div class="bloque-contenido">
    <div class="parrafo-bio">
      <p>{textoBiografico}</p>
    </div>
    
    {imagenes.length > 0 && (
      <div class="galeria-imagenes">
        {imagenes.map((url) => (
          <img src={url} alt="Imagen de galería del vendedor" class="foto-galeria" />
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .seccion-info {
    height: 100%; /* Ocupa todo el alto disponible en el grid */
    padding: 2.5rem;
    color: #ffffff; /* Ajustar según contraste de colorFondo */
  }
  
  .parrafo-bio {
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .galeria-imagenes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .foto-galeria {
    width: 100%;
    aspect-ratio: 16 / 9; /* Imágenes panorámicas uniformes */
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.2);
  }
</style>