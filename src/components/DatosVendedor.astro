---
// src/components/DatosVendedor.astro
interface Props {
  fotoPerfil: string;
  ubicacion?: string;
  telefono?: string;
  correo?: string;
  enlaceWeb?: string;
}

const { fotoPerfil, ubicacion, telefono, correo, enlaceWeb } = Astro.props;
---

<article class="tarjeta-contacto">
  {/* Foto CUADRADA */}
  <img src={fotoPerfil} alt="Logotipo o perfil del vendedor" class="foto-cuadrada" />
  
  <div class="info-listado">
    {/* Textos de seguridad por si no hay datos */}
    <p class="dato-linea">
     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M12 2C8.69 2 6 4.69 6 8c0 4.5 6 12 6 12s6-7.5 6-12c0-3.31-2.69-6-6-6zm0 8.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 5.5 12 5.5s2.5 1.12 2.5 2.5S13.38 10.5 12 10.5z"/>
                  </svg>
      <strong>Ubicación:</strong> {ubicacion || 'Dirección no disponible'}
    </p>
    <p class="dato-linea">
      
     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </svg>
                  
      <strong>Teléfono:</strong> {telefono || 'No proporcionado'}
    </p>
    <p class="dato-linea">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zm8 7L4 6v12h16V6l-8 5z"/>
                  </svg>
      <strong>Correo:</strong> {correo || 'Sin email de contacto'}
    </p>
    
    {enlaceWeb && (
      <a href={enlaceWeb} target="_blank" class="boton-visitar" rel="noopener noreferrer">
        Visitar Sitio Web
      </a>
    )}
  </div>
</article>

<style>
  .tarjeta-contacto {
    display: flex;
    flex-direction: column; /* Stack vertical para columna estrecha */
    align-items: center;
    padding: 2rem;
    background-color: #ffffff;
    border: 1px solid #eaeaea;
    border-radius: 8px;
    text-align: center;
  }

  .foto-cuadrada {
    width: 150px;
    height: 150px;
    /* border-radius eliminado para que sea cuadrada */
    object-fit: contain; /* Ideal si es un logo con fondo blanco */
    margin-bottom: 1.5rem;
    border: 1px solid #f0f0f0;
    padding: 5px;
    background: white;
  }

  .info-listado {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dato-linea {
    margin: 0;
    font-size: 0.95rem;
    color: #444;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .icono { font-size: 1.1rem; }

  .boton-visitar {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 10px 20px;
    background-color: #1a1a1a; /* Color neutro oscuro */
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .boton-visitar:hover { background-color: #333; }
</style>