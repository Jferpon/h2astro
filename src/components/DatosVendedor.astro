---
// src/components/DatosVendedor.astro
interface Props {
  fotoPerfil: string;
  ubicacion?: string;
  telefono?: string;
  correo?: string;
  enlaceWeb?: string;
}

const { fotoPerfil, ubicacion, telefono, correo, enlaceWeb } = Astro.props;
---

<article class="tarjeta-contacto">
  {/* Foto CUADRADA */}
  <img src={fotoPerfil} alt="Logotipo o perfil del vendedor" class="foto-cuadrada" />
  
  <div class="info-listado">
    {/* Textos de seguridad por si no hay datos */}
    <p class="dato-linea">
      <span class="icono">📍</span> 
      <strong>Ubicación:</strong> {ubicacion || 'Dirección no disponible'}
    </p>
    <p class="dato-linea">
      <span class="icono">📞</span> 
      <strong>Teléfono:</strong> {telefono || 'No proporcionado'}
    </p>
    <p class="dato-linea">
      <span class="icono">📧</span> 
      <strong>Correo:</strong> {correo || 'Sin email de contacto'}
    </p>
    
    {enlaceWeb && (
      <a href={enlaceWeb} target="_blank" class="boton-visitar" rel="noopener noreferrer">
        Visitar Sitio Web
      </a>
    )}
  </div>
</article>

<style>
  .tarjeta-contacto {
    display: flex;
    flex-direction: column; /* Stack vertical para columna estrecha */
    align-items: center;
    padding: 2rem;
    background-color: #ffffff;
    border: 1px solid #eaeaea;
    border-radius: 8px;
    text-align: center;
  }

  .foto-cuadrada {
    width: 150px;
    height: 150px;
    /* border-radius eliminado para que sea cuadrada */
    object-fit: contain; /* Ideal si es un logo con fondo blanco */
    margin-bottom: 1.5rem;
    border: 1px solid #f0f0f0;
    padding: 5px;
    background: white;
  }

  .info-listado {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dato-linea {
    margin: 0;
    font-size: 0.95rem;
    color: #444;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .icono { font-size: 1.1rem; }

  .boton-visitar {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 10px 20px;
    background-color: #1a1a1a; /* Color neutro oscuro */
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .boton-visitar:hover { background-color: #333; }
</style>