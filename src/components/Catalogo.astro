---
interface Props {
  fotos: {
    src: string;
    alt: string;
    href: string; // <-- Ahora el enlace es obligatorio
  }[];
}

const { fotos } = Astro.props;
---

<div class="proveedores">
  {
    fotos.map((foto) => (
      <a href={foto.href} class="logo-link" target="_blank" rel="noopener noreferrer">
        <img src={foto.src} alt={foto.alt} loading="lazy" />
      </a>
    ))
  }
</div>

<style>
  .proveedores {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: center;
    justify-items: center;
    margin: 40px 0;
  }

  /* Estilos para el enlace */
  .logo-link {
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    transition: transform 0.3s ease; /* El movimiento se aplica al enlace */
  }

  .logo-link img {
    max-width: 120px;
    height: auto;
    object-fit: contain;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  /* Efecto Hover: aumenta el enlace y la opacidad de la imagen */
  .logo-link:hover {
    transform: scale(1.15);
  }

  .logo-link:hover img {
    opacity: 1;
  }

  /* Responsive se mantiene igual... */
  @media (max-width: 768px) {
    .proveedores { grid-template-columns: repeat(3, 1fr); }
    .logo-link img { max-width: 110px; }
  }
  @media (max-width: 480px) {
    .proveedores { grid-template-columns: repeat(2, 1fr); }
    .logo-link img { max-width: 90px; }
  }
</style>