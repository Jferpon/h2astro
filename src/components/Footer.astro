---
const today = new Date();
---

<style>
  footer {
    background-color: #2b2b2b;
    color: #ffffff;
    padding: 2.5em 1em 1em 1em;
    font-family: Arial, sans-serif;
    font-size: 0.9rem;
  }

  /* Contenedor principal: tres columnas */
  footer .top-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto 1.5em auto;
    gap: 2em;
  }

  /* Logo */
  footer .logo img {
    width: 10rem;
    height: auto;
  }

  /* Datos de contacto */
  footer .contact-info h4 {
    color: white;
    margin: 0 0 0.5em 0;
    font-weight: 700;
  }
  footer .contact-info {
    flex: 1;
    font-size: 1rem; /* mismo tamaño que enlaces */
    margin-left: 18rem; /* separa de logo */
  }

  footer .contact-info strong {
    font-weight: 700;
    color:white
  }

  footer .contact-info a {
    color: #ffffff52;
    text-decoration: none;
  }

  footer .contact-info a:hover {
    color: #ffd700;
  }

  /* Enlaces + redes sociales */
  footer .right-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-left: -5rem;
  }

  footer aside h4 {
    color: white;
    margin: 0 0 0.5em 0;
    font-weight: 700;
  }

  footer aside ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  footer aside li {
    margin-bottom: 0.5em;
  }

  footer aside a {
    color: #ffffff52;
    text-decoration: none;
    transition: color 0.2s;
    font-size: 1rem; 
  }

  footer aside a:hover {
    color: #ffd700;
  }

  footer .social-links {
    display: flex;
    gap: 1em;
  }

  footer .social-links a {
    color: white;
    width: 28px;
    height: 28px;
    display: inline-flex;
  }

  footer .social-links svg {
    fill: currentColor;
    width: 100%;
    height: 100%;
    transition: opacity 0.2s ease;
  }

  footer .social-links a:hover svg {
    opacity: 0.7;
  }

  /* Línea separadora */
  footer hr {
    border: 0;
    border-top: 1px solid #555555;
    margin: 1.5em 0;
  }

  /* Copy centrado */
  footer .copy {
    text-align: center;
    font-size: 0.9rem;
    margin-top: 1em;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    footer .top-section {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    footer .contact-info,
    footer .right-column {
      align-items: center;
      margin-left: 0;
      margin-top: 1em;
    }

    footer .social-links {
      justify-content: center;
    }
  }
</style>

<footer>
  <div class="top-section">
    <!-- Logo -->
    <div class="logo">
      <img src="/logoFooter.png" alt="Logo Achedosol" title="Achedosol" />
    </div>

    <!-- Datos de contacto -->
    <div class="contact-info">
     <h4>Datos de contacto</h4>
      Tienda Central Achedosol C/ Franklin, 19 <br/>
      29680 Estepona, Málaga, España
      <br/>
      <strong>Llámanos ahora:</strong> 952804696
      <br/>
      <strong>Email:</strong> <a href="mailto:proyectos@montestorres.es">proyectos@montestorres.es</a>
    </div>

    <!-- Enlaces de interés + redes sociales -->
    <div class="right-column">
      <aside>
        <h4>Enlaces de interés</h4>
        <ul>
          <li><a href="#">Aviso legal y condiciones generales de uso</a></li>
          <li><a href="#">Política de cookies</a></li>
        </ul>
      </aside>

      <div class="social-links">
        <a href="https://www.instagram.com/achedosol_montestorres/" target="_blank" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 2C4.243 2 2 4.243 2 7v10c0 2.757 2.243 5 5 5h10c2.757 0 5-2.243 5-5V7c0-2.757-2.243-5-5-5H7zm10 2a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3h10zm-5 3a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm4.5-.75a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"></path>
          </svg>
        </a>

        <a href="https://www.facebook.com/people/Achedosol/100057272628175/?_rdr" target="_blank" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12a10 10 0 10-11.5 9.9v-7H8v-2.9h2.5V9.5c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.7-1.6 1.5v1.8h2.8L16 14.9h-2.2v7A10 10 0 0022 12z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Línea separadora -->
  <hr />

  <!-- Copy centrado -->
  <div class="copy">
    &copy; {today.getFullYear()} Achedosol
  </div>
</footer>
