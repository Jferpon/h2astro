---
import Image from "astro/components/Image.astro";

const today = new Date();
---
 
<style>
  footer {
    /* 1. GRIS FIJO: Siempre este color, ignore el theme */
    background-color: var(--footer-bg);
    color: #ffffff;
    padding: 3em 2rem 1.5em 2rem;
    font-family: Arial, sans-serif;
    font-size: 0.85rem;
  }

  /* Contenedor principal */
  footer .top-section {
    display: grid;
    /* 2. ESPACIADO CONTROLADO: 'auto' hace que la columna solo ocupe lo que necesita su texto */
    grid-template-columns: auto auto auto; 
    /* Centramos todo el bloque de las 3 columnas en el medio del footer */
    justify-content: center; 
    align-items: flex-start;
    max-width: 1200px;
    margin: 0 auto 2em auto;
    /* Ajusta este gap para acercar o alejar Y de Z */
    gap: clamp(2rem, 8vw, 6rem); 
  }

  /* Logo (X) */
  footer .logo img {
    width: clamp(80px, 12vw, 150px);
    height: auto;
    display: block;
  }

  /* Datos de contacto (Y) */
  footer .contact-info {
    font-size: 0.92rem; /* Un poco más grande que los enlaces */
    line-height: 1.5;
    max-width: 300px; /* Evitamos que el texto se estire demasiado */
  }
  
  footer .contact-info h4, footer aside h4 {
    color: #ffffff;
    margin: 0 0 0.8em 0;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  footer .contact-info a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  /* Enlaces e Interés (Z) */
  footer .right-column {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  footer aside ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  footer aside a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.85rem; /* Un poco más pequeña que el contacto */
    display: block;
    margin-bottom: 0.4rem;
  }

  /* 3. HOVER AMARILLO */
  footer aside a:hover, 
  footer .contact-info a:hover {
    color: #ffd700 !important; 
  }

  footer .social-links {
    display: flex;
    gap: 1rem;
  }

  footer .social-links svg {
    fill: #ffffff;
    width: 22px;
    height: 22px;
    transition: fill 0.2s, transform 0.2s;
  }

  footer .social-links a:hover svg {
    fill: #ffd700;
    transform: scale(1.1);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1024px) {
    footer .top-section {
      /* Reducimos el espacio entre columnas en tablets */
      gap: 3rem; 
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 2em 1rem;
    }

    footer .top-section {
      /* En móviles mantenemos X--Y--Z pero con espacio mínimo */
      grid-template-columns: auto auto auto;
      gap: 1rem;
      justify-content: space-between;
    }

    footer .logo img {
      max-width: 65px;
      margin-top: 2rem;
    }

    footer .contact-info, 
    footer aside a {
      font-size: 0.75rem;
    }
    
    footer .contact-info h4, footer aside h4 {
      font-size: 0.8rem;
    }
  }

  footer hr {
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 1.5em 0;
  }

  footer .copy {
    text-align: center;
    opacity: 0.5;
    font-size: 0.75rem;
    color: #fff;
  }
</style>

<footer>
  <div class="top-section">
    <!-- Logo -->
    <div class="logo">
     <Image src="/logoFooter.png" alt="Logo Achedosol" title="Achedosol" width={150} height={150} />
    </div>

    <!-- Datos de contacto -->
    <div class="contact-info">
     <h4>Datos de contacto</h4>
      Tienda Central Achedosol C/ Franklin, 19 <br/>
      29680 Estepona, Málaga, España
      <br/>
      <strong>Llámanos ahora:</strong> 952804696
      <br/>
      <strong>Email:</strong> <a href="mailto:proyectos@montestorres.es">proyectos@montestorres.es</a>
    </div>

    <!-- Enlaces de interés + redes sociales -->
    <div class="right-column">
      <aside>
        <h4>Enlaces de interés</h4>
        <ul>
          <li><a href="/legal">Aviso legal y condiciones generales de uso</a></li>
          <li><a href="/cookies">Política de cookies</a></li>
        </ul>
      </aside>

      <div class="social-links">
        <a href="https://www.instagram.com/achedosol_montestorres/" target="_blank" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 2C4.243 2 2 4.243 2 7v10c0 2.757 2.243 5 5 5h10c2.757 0 5-2.243 5-5V7c0-2.757-2.243-5-5-5H7zm10 2a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3h10zm-5 3a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm4.5-.75a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"></path>
          </svg>
        </a>

        <a href="https://www.facebook.com/people/Achedosol/100057272628175/?_rdr" target="_blank" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12a10 10 0 10-11.5 9.9v-7H8v-2.9h2.5V9.5c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.7-1.6 1.5v1.8h2.8L16 14.9h-2.2v7A10 10 0 0022 12z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Línea separadora -->
  <hr />

  <!-- Copy centrado -->
  <div class="copy">
    &copy; {today.getFullYear()} Achedosol
  </div>
</footer>
