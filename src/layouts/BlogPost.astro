---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: string;
  hideUI?: boolean; // Mantenemos hideUI en la interfaz
}

const { title, description, pubDate, updatedDate, heroImage, hideUI=false } = Astro.props;

// Comprobamos si es una página legal (sin fecha) para ajustar el estilo
const isLegalPage = !pubDate;
---

<html lang="es">
<head>
  <script is:inline>
      // Lógica de Modo Oscuro (se mantiene igual)
      const applyTheme = () => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();

        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  <BaseHead title={title} description={description} />
  <style>
    
    /* Estilos base (se mantienen igual) */
    main {
      width: 100%;
      max-width: 100%;
      margin: 0;
    }

    .hero-image {
      width: 100%;
    }

    .hero-image img {
      display: block;
      margin: 0 auto;
      border-radius: 12px;
      box-shadow: var(--box-shadow);
    }

    .prose {
      width: 900px;
      max-width: calc(100% - 2em);
      margin: auto;
      padding: 1em;
      color: rgb(var(--gray-dark));
    }

    .title {
      margin-bottom: 1em;
      padding: 1em 0 0 0;
      text-align: var(--title-align, center); 
      line-height: 1.2;
    }

    .title h1 {
      margin: 0 0 0.5em 0;
      font-size: 2.5rem;
    }

    .date {
      margin-bottom: 0.5em;
      color: rgb(var(--gray));
    }

    .last-updated-on {
      font-style: italic;
    }

    .align-left {
      text-align: left !important;
    }
  </style>
  
</head>

<body>
  {!hideUI && <Header />}

  <main>
    {hideUI ? (
      // Si hideUI es true, renderizamos el <slot /> directamente.
      // Esto elimina cualquier envoltorio (<article>, <div>, clases prose) y sus márgenes.
      <slot />
    ) : (
      // Si hideUI es false, mantenemos la estructura clásica del blog.
      <article>
        {heroImage && (
          <div class="hero-image">
            <Image width={1020} height={510} src={heroImage} alt="" />
          </div>
        )}

        <div class="prose">
          <div class={isLegalPage ? "title align-left" : "title"}>
            {pubDate && (
              <div class="date">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <div class="last-updated-on">
                    Última actualización el <FormattedDate date={updatedDate} />
                  </div>
                )}
              </div>
            )}
            <h1>{title}</h1>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    )}
  </main>

  {!hideUI && <Footer />}
</body>
</html>